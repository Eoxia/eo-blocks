{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "eo/sticky",
	"version": "1.0.0",
	"title": "Sticky",
	"category": "eo-blocks",
	"icon": "smiley",
	"description": "Display sticky block",
	"example": {},
  	"attributes": {
		"contentPosition": {
			"type": "string",
			"default": "top right"
		},
		"horizontalGapPercent": {
			"type": "number",
			"default": 0
		},
		"verticalGapPercent": {
			"type": "number",
			"default": 0
		}
  	},
	"supports": {
		"color": {
			"background": "true",
			"color": "true"
		},
		"spacing": {
			"margin": false,
			"padding": true,
			"blockGap": true
		}
	},
	"textdomain": "accordion",
	"editorScript": "file:./index.js",
	"editorStyle": "file:./index.css",
	"style": "file:./style-index.css",
  	"render": "file:./render.php",
	"viewScript": "file:./view.js"
}

{
	"name": "eo-blocks",
	"version": "0.1.0",
	"description": "A collection of Gutenberg blocks for WordPress made by Eoxia",
	"author": "Eoxia",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"build:hooks": "wp-scripts build hooks/src/index.js --output-path=hooks/build/ --output-filename=hooks.js",
		"format": "wp-scripts format",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "wp-scripts lint-js",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --webpack-src-dir=blocks/src/ --output-path=blocks/build/",
		"start:hooks": "wp-scripts start hooks/src/index.js --output-path=hooks/build/ --output-filename=hooks.js",
		"start:scss": "node node_modules/gulp/bin/gulp.js",
		"start:all": "npm-run-all --parallel start start:hooks start:scss"
	},
	"devDependencies": {
		"@wordpress/scripts": "^27.9.0",
		"gulp": "^4.0.0",
		"gulp-autoprefixer": "^6.0.0",
		"gulp-concat": "latest",
		"gulp-dest": "^0.2.3",
		"gulp-line-ending-corrector": "^1.0.3",
		"gulp-path": "^4.0.0",
		"gulp-rename": "latest",
		"gulp-sass": "latest",
		"gulp-watch": "latest",
		"npm-run-all": "^4.1.5",
		"sass": "latest"
	},
	"dependencies": {
		"@wordpress/icons": "^10.10.0",
		"classnames": "^2.5.1"
	}
}
